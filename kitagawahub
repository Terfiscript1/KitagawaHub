                PhoneAddBtn.Text = "Add Btn"
                PhoneAddBtn.TextColor3 = Color3.fromRGB(180, 180, 180)
                PhoneAddBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
                return 
            end
            
            PhoneAddBtn.Text = "Del Btn"
            PhoneAddBtn.TextColor3 = Color3.fromRGB(255, 76, 76)
            PhoneAddBtn.BackgroundColor3 = Color3.fromRGB(45, 25, 25)
            
            MobWrapper = Instance.new("Frame", MobileContainer)
            MobWrapper.Size = UDim2.new(0, 100, 0, 42)
            MobWrapper.Position = UDim2.new(0.5, -50, 0.5, 0)
            MobWrapper.BackgroundTransparency = 1
            
            createdMobBtn = Instance.new("TextButton", MobWrapper)
            createdMobBtn.Size = UDim2.new(1, 0, 1, 0)
            createdMobBtn.Position = UDim2.new(0, 0, 0, 0)
            createdMobBtn.BackgroundColor3 = Color3.fromRGB(24, 24, 30)
            createdMobBtn.Text = text .. "\n" .. (Config[configName].Enabled and "[ON]" or "[OFF]")
            createdMobBtn.TextColor3 = Config[configName].Enabled and Color3.fromRGB(46, 204, 113) or Color3.fromRGB(231, 76, 60)
            createdMobBtn.Font = Enum.Font.GothamBold
            createdMobBtn.TextSize = 11
            Instance.new("UICorner", createdMobBtn).CornerRadius = UDim.new(0, 8)
            local MStroke = Instance.new("UIStroke", createdMobBtn)
            MStroke.Color = Config[configName].Enabled and Color3.fromRGB(46, 204, 113) or Color3.fromRGB(35, 35, 45)
            MStroke.Thickness = 1.5
            
            local mDragging, mDragStart, mStartPos = false, nil, nil
            createdMobBtn.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    mDragging = true
                    mDragStart = input.Position
                    mStartPos = MobWrapper.Position
                    input.Changed:Connect(function()
                        if input.UserInputState == Enum.UserInputState.End then
                            mDragging = false
                        end
                    end)
                end
            end)
            
            UserInputService.InputChanged:Connect(function(input)
                if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) and mDragging then
                    local delta = input.Position - mDragStart
                    MobWrapper.Position = UDim2.new(mStartPos.X.Scale, mStartPos.X.Offset + delta.X, mStartPos.Y.Scale, mStartPos.Y.Offset + delta.Y)
                end
            end)
            
