    local TStroke = Instance.new("UIStroke", ToggleBg)
    TStroke.Color = Color3.fromRGB(60, 60, 65)
    
    local Dot = Instance.new("Frame", ToggleBg)
    Dot.Size = UDim2.new(0, 17, 0, 17)
    Dot.Position = UDim2.new(0, 3, 0.5, -8.5)
    Dot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", Dot).CornerRadius = UDim.new(1, 0)

    local MobWrapper = nil
    local createdMobBtn = nil
    
    local function updateVisuals(targetState)
        Config[configName].Enabled = targetState
        local targetPos = targetState and UDim2.new(1, -20, 0.5, -8.5) or UDim2.new(0, 3, 0.5, -8.5)
        local targetColor = targetState and Color3.fromRGB(46, 204, 113) or Color3.fromRGB(45, 45, 50)
        local targetStroke = targetState and Color3.fromRGB(40, 180, 100) or Color3.fromRGB(60, 60, 65)
        TweenService:Create(Dot, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Position = targetPos}):Play()
        TweenService:Create(ToggleBg, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundColor3 = targetColor}):Play()
        TStroke.Color = targetStroke
        UpdateKeyBindList()
        
        if createdMobBtn then
            if targetState then
                createdMobBtn.Text = text .. "\n[ON]"
                createdMobBtn.TextColor3 = Color3.fromRGB(46, 204, 113)
                createdMobBtn:FindFirstChildOfClass("UIStroke").Color = Color3.fromRGB(46, 204, 113)
            else
                createdMobBtn.Text = text .. "\n[OFF]"
                createdMobBtn.TextColor3 = Color3.fromRGB(231, 76, 60)
                createdMobBtn:FindFirstChildOfClass("UIStroke").Color = Color3.fromRGB(35, 35, 45)
            end
        end
        if callback then callback(targetState) end
    end
    
    ToggleUpdaters[configName] = updateVisuals
    ToggleReseters[configName] = function() updateVisuals(false) end
    ToggleBg.MouseButton1Click:Connect(function() updateVisuals(not Config[configName].Enabled) end)
    
    if hasBind then
