        if not Authorized then continue end
        if Config.WallShot.Enabled and not wallShotCooldown then
            local character = LocalPlayer.Character
            local backpack = LocalPlayer:FindFirstChild("Backpack")
            local myWeapon = nil
            local function findGun(container)
                if not container then return end
                for _, item in pairs(container:GetChildren()) do
                    if item:IsA("Tool") and (string.find(item.Name:lower(), "weapon") or string.find(item.Name:lower(), "gun")) then return item end
                end
            end
            myWeapon = findGun(character) or findGun(backpack)
            if not myWeapon then
                CreateCustomNotification("❌ You dont have Weapon", Color3.fromRGB(231, 76, 60))
                if ToggleReseters["WallShot"] then ToggleReseters["WallShot"]() end
                task.wait(1)
            else
                local murderer = nil
                for _, p in pairs(Players:GetPlayers()) do
                    if checkPlayerRole(p) == "Knife" and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then murderer = p break end
                end
                if murderer and character and character:FindFirstChild("HumanoidRootPart") then
                    wallShotCooldown = true
                    if myWeapon.Parent == backpack then myWeapon.Parent = character end
                    local mHRP = murderer.Character.HumanoidRootPart
                    SeamlessTeleport(mHRP.CFrame, 0.12, function()
