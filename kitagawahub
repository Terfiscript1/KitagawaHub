local PlayerFrames = {} 
local function PopulateTrollList()
    if not Authorized then return end
    local filterText = SearchBar.Text:lower()
    local currentValidPlayers = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and (filterText == "" or p.Name:lower():find(filterText) or p.DisplayName:lower():find(filterText)) then
            currentValidPlayers[p.UserId] = p
        end
    end
    for userId, frame in pairs(PlayerFrames) do
        if not currentValidPlayers[userId] then frame:Destroy(); PlayerFrames[userId] = nil end
    end
    for _, child in pairs(TrollListContainer:GetChildren()) do
        if child:IsA("Frame") and not PlayerFrames[tonumber(child.Name)] then child:Destroy() end
    end
    for userId, p in pairs(currentValidPlayers) do
        local role = checkPlayerRole(p)
        local roleDisplayStr = "Innocent"
        local roleColor = Color3.fromRGB(150, 150, 150)
        local weight = 3
        if role == "Knife" then roleDisplayStr = "Murderer"; roleColor = Color3.fromRGB(255, 50, 50); weight = 1
        elseif role == "Weapon" then roleDisplayStr = "Sheriff"; roleColor = Color3.fromRGB(50, 150, 255); weight = 2 end

        local PlayerFrame = PlayerFrames[userId]
        if not PlayerFrame then
            PlayerFrame = Instance.new("Frame", TrollListContainer)
            PlayerFrame.Name = tostring(userId)
            PlayerFrame.Size = UDim2.new(0, 370, 0, 50)
            PlayerFrame.BackgroundColor3 = Color3.fromRGB(24, 24, 28)
            PlayerFrame.BackgroundTransparency = 0.15
            Instance.new("UICorner", PlayerFrame).CornerRadius = UDim.new(0, 8)
            Instance.new("UIStroke", PlayerFrame).Color = Color3.fromRGB(35, 35, 42)
            
            local Avatar = Instance.new("ImageLabel", PlayerFrame)
            Avatar.Size = UDim2.new(0, 40, 0, 40)
            Avatar.Position = UDim2.new(0, 5, 0, 5)
            Avatar.BackgroundTransparency = 1
            pcall(function() Avatar.Image = Players:GetUserThumbnailAsync(p.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48) end)
            Instance.new("UICorner", Avatar).CornerRadius = UDim.new(1, 0)
            
            local NameLabel = Instance.new("TextLabel", PlayerFrame)
            NameLabel.Name = "PlayerNameLabel"
            NameLabel.Size = UDim2.new(1, -60, 0, 18)
            NameLabel.Position = UDim2.new(0, 55, 0, 6)
            NameLabel.BackgroundTransparency = 1
            NameLabel.Text = p.DisplayName .. " (@" .. p.Name .. ")"
            NameLabel.TextColor3 = Color3.fromRGB(225, 225, 230)
            NameLabel.TextSize = 14
            NameLabel.Font = Enum.Font.GothamSemibold
            NameLabel.TextXAlignment = Enum.TextXAlignment.Left
            
            local RoleLabel = Instance.new("TextLabel", PlayerFrame)
            RoleLabel.Name = "PlayerRoleLabel"
            RoleLabel.Size = UDim2.new(1, -60, 0, 16)
            RoleLabel.Position = UDim2.new(0, 55, 0, 28)
            RoleLabel.BackgroundTransparency = 1
            RoleLabel.TextSize = 12
            RoleLabel.Font = Enum.Font.GothamBold
            RoleLabel.TextXAlignment = Enum.TextXAlignment.Left
            
            local ClickBtn = Instance.new("TextButton", PlayerFrame)
            ClickBtn.Size = UDim2.new(1, 0, 1, 0)
            ClickBtn.BackgroundTransparency = 1
            ClickBtn.Text = ""
            ClickBtn.MouseButton1Click:Connect(function() CreateCustomNotification("Flinging " .. p.DisplayName .. "...", Color3.fromRGB(255, 30, 120)); SkidFling(p) end)
            
            PlayerFrames[userId] = PlayerFrame
        end
        local RoleLabel = PlayerFrame:FindFirstChild("PlayerRoleLabel")
        if RoleLabel then RoleLabel.Text = roleDisplayStr; RoleLabel.TextColor3 = roleColor end
        PlayerFrame.LayoutOrder = weight * 1000 + (p.Name:lower():byte(1) or 0)
    end
end
