local function isDroppedGun(obj)
    local name = obj.Name:lower()
    if name == "gun" or name == "dropgun" or name == "gundrop" or name == "weapon" then
        if obj:IsA("BasePart") or obj:IsA("Model") then
            local parent = obj.Parent
            -- Оптимизировано: убран тяжелый while цикл. 
            if parent == workspace or (parent and parent:IsA("Model") and not parent:FindFirstChild("Humanoid")) or (parent and parent:IsA("Folder")) then
                return true
            end
        end
    end
    return false
end

local function CleanGunESP()
    for obj, espData in pairs(ActiveGunESPs) do
        if espData.Highlight and espData.Highlight.Parent then espData.Highlight:Destroy() end
        if espData.Billboard and espData.Billboard.Parent then espData.Billboard:Destroy() end
    end
    table.clear(ActiveGunESPs)
end

local function SeamlessTeleport(targetCFrame, waitTime, actionCallback)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart
    local cam = workspace.CurrentCamera
    local originalCFrame = hrp.CFrame
    local originalCamCFrame = cam.CFrame
    local originalCamType = cam.CameraType
    local originalVelocity = hrp.AssemblyLinearVelocity
    
    cam.CameraType = Enum.CameraType.Scriptable
    cam.CFrame = originalCamCFrame
    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.CFrame = targetCFrame
    if actionCallback then actionCallback() end
    task.wait(waitTime)
    hrp.CFrame = originalCFrame
    hrp.AssemblyLinearVelocity = originalVelocity
    cam.CameraType = originalCamType
    cam.CFrame = originalCamCFrame
end

