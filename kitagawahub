-- УТИЛИТЫ И ПРОВЕРКИ
-- ==========================================
local function checkPlayerRole(player)
    if not player then return "Default" end
    local character = player.Character
    local backpack = player:FindFirstChild("Backpack")
    local hasKnife, hasWeapon = false, false
    
    local function checkItems(container)
        if not container then return end
        for _, item in pairs(container:GetChildren()) do
            if item:IsA("Tool") then
                local nameLower = item.Name:lower()
                if string.find(nameLower, "knife") then hasKnife = true
                elseif string.find(nameLower, "weapon") or string.find(nameLower, "gun") then hasWeapon = true end
            end
        end
    end
    checkItems(character)
    checkItems(backpack)
    if hasKnife then return "Knife" end
    if hasWeapon then return "Weapon" end
    return "Default"
end

